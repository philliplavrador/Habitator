# ── Habitator environment variables ────────────────────────────────
# Copy to `.env.local` for local dev. Set these in the Railway dashboard
# (service → Variables) for production.

# The single shared password you type on the /login screen.
APP_PASSWORD=change-me

# A long random string used as the opaque "logged in" cookie value.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Absolute path to the SQLite file. In production point this at the
# Railway volume mount, e.g. /data/habitator.db
# If unset, the app falls back to ./data/habitator.db (local dev only).
DATABASE_PATH=

# Your timezone, so the app's "today" matches your local day. Hosts like Railway
# default to UTC — without this, near midnight the app could show the wrong day.
# Use a TZ database name, e.g. America/New_York, Europe/London, Australia/Sydney.
# (Local dev already uses your machine's timezone, so you can leave this blank.)
TZ=
