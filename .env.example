# ── Habitator environment variables ────────────────────────────────
# Copy to `.env.local` for local dev. Set these in the Railway dashboard
# (service → Variables) for production.

# The single shared password you type on the /login screen.
APP_PASSWORD=change-me

# A long random string used as the opaque "logged in" cookie value.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Absolute path to the SQLite file. In production point this at the
# Railway volume mount, e.g. /data/habitator.db
# If unset, the app falls back to ./data/habitator.db (local dev only).
DATABASE_PATH=

# Timezone is auto-detected from your browser and remembered in a cookie, so you
# normally DON'T need to set this. TZ is only the fallback for the very first page
# load of a fresh session (before the browser reports in). Hosts like Railway
# default to UTC; set TZ to your zone (e.g. America/New_York, Europe/London,
# Australia/Sydney) to make even that first paint match your local day.
TZ=
