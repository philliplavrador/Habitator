# ── Habitator environment variables ────────────────────────────────
# Copy to `.env.local` for local dev. Set these in the Railway dashboard
# (service → Variables) for production.

# ── Auth ─────────────────────────────────────────────────────────────
# HMAC key used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Shared code required to CREATE a new account on the login screen. Existing
# users just type their username + password; creating a brand-new username also
# requires this code. Leave it UNSET to disable sign-ups entirely (only accounts
# that already exist can log in).
REGISTRATION_CODE=change-me

# ── Database (PostgreSQL) ────────────────────────────────────────────
# Connection string for Postgres. On Railway, add the Postgres plugin and it
# exposes DATABASE_URL automatically (reference it as ${{Postgres.DATABASE_URL}}).
# Locally, point at your own Postgres, e.g. a Docker container:
#   postgres://postgres:devpass@localhost:55432/habitator
DATABASE_URL=

# TLS mode for the DB connection: `disable`, `require`, or unset (auto — off for
# localhost / Railway's private network, on for external hosts).
PGSSL=

# ── One-time SQLite → Postgres migration ─────────────────────────────
# Path to the OLD SQLite database file. If set and the file exists, on first
# boot every row is copied into Postgres under the "Fifi" account (once — a flag
# then prevents re-runs). Leave the file in place afterward as a backup. Unset
# this once the migration has run and been verified.
#   Prod: the Railway volume path, e.g. /data/habitator.db
DATABASE_PATH=

# Base directory for app-managed files. Uploaded rep-program videos are stored
# in <DATA_DIR>/uploads/ (put this on a persistent volume in prod). Defaults to
# the directory of DATABASE_PATH, or ./data locally.
DATA_DIR=

# Optional: override the seeded password for the migrated "Fifi" account on a
# FRESH database. If unset, Fifi is seeded with the owner's chosen password.
SEED_FIFI_PASSWORD=

# ── Timezone ─────────────────────────────────────────────────────────
# Auto-detected from the browser and remembered in a cookie, so you normally
# DON'T need this. TZ is only the fallback for the very first page load. Hosts
# like Railway default to UTC; set TZ to your zone (e.g. America/New_York) so
# even that first paint matches your local day.
TZ=
